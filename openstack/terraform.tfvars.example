cloud = "my-openstack-cloud"
deployment_mode = "consolidated" # or "distributed" for three VMs
# Optional: reuse existing resources. Omit to discover Ubuntu and create a
# tenant network, subnet, and router.
# image_id = "00000000-0000-0000-0000-000000000000"
# network_id = "00000000-0000-0000-0000-000000000000"
admin_cidr = "203.0.113.10/32"
ssh_public_key = "ssh-ed25519 AAAA..."
passbolt_domain = "passbolt.example.com"
mariadb_root_password = "replace-me"
nextcloud_db_password = "replace-me"
passbolt_db_password = "replace-me"
nextcloud_admin_password = "replace-me"
